#!/bin/bash
#SBATCH --job-name=VJEPA2-EXP__hdepic_tri_modal_fusion
#SBATCH --account=torch_pr_674_tandon_advanced
#SBATCH --partition=h100_tandon
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --gres=gpu:h100:1
#SBATCH --cpus-per-task=12
#SBATCH --mem=768GB
#SBATCH --time=48:00:00
#SBATCH --output=/scratch/ll5914/logs/hdepic_tri_modal_fusion_%j.out
#SBATCH --error=/scratch/ll5914/logs/hdepic_tri_modal_fusion_%j.err
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=<email>

set -euo pipefail

# Tri-modal projected cross-attention fusion: separate video / gaze / IMU encoders
# with fusion between frozen V-JEPA encoder output and predictor input.

PROJECT_ROOT="${PROJECT_ROOT:-/home/ll5914/Jepa_yifan/JEPA_ARVR}"
CHECKPOINT="${CHECKPOINT:-/scratch/ll5914/models/vjepa2/vitl.pt}"

export PROJECT_ROOT
export GAZE_MODE=projected_tri_modal_cross_attention
export GAZE_ROOT="${GAZE_ROOT:-/scratch/ll5914/datasets/HD-EPIC/SLAM-and-Gaze}"
export GAZE_EXTRACT_ROOT="${GAZE_EXTRACT_ROOT:-/scratch/ll5914/datasets/HD-EPIC/_gaze_extract}"
export GAZE_SYNC_ROOT="${GAZE_SYNC_ROOT:-/scratch/ll5914/datasets/HD-EPIC/Videos}"

export LORA_PROBE_TRAIN_MODE="${LORA_PROBE_TRAIN_MODE:-full}"
export EVAL_SINGLE_PROBE="${EVAL_SINGLE_PROBE:-1}"
export EVAL_LR="${EVAL_LR:-0.0001}"
export EVAL_START_LR="${EVAL_START_LR:-0.0}"
export EVAL_FINAL_LR="${EVAL_FINAL_LR:-0.0}"
export EVAL_WARMUP_EPOCHS="${EVAL_WARMUP_EPOCHS:-2}"
export EVAL_WEIGHT_DECAY="${EVAL_WEIGHT_DECAY:-0.0001}"
export EVAL_FINAL_WEIGHT_DECAY="${EVAL_FINAL_WEIGHT_DECAY:-0.0001}"
export EVAL_USE_FOCAL_LOSS="${EVAL_USE_FOCAL_LOSS:-0}"
export EVAL_GRAD_CLIP="${EVAL_GRAD_CLIP:-1.0}"
export EVAL_NUM_EPOCHS="${EVAL_NUM_EPOCHS:-10}"
export EVAL_BATCH_SIZE="${EVAL_BATCH_SIZE:-4}"
export LORA_PRETRAINED_PROBE="${LORA_PRETRAINED_PROBE-}"

export LORA_RANK="${LORA_RANK:-8}"
export LORA_ALPHA="${LORA_ALPHA:-16.0}"
export LORA_DROPOUT="${LORA_DROPOUT:-0.05}"

export ENCODER_LORA_ENABLED="${ENCODER_LORA_ENABLED:-1}"
export ENCODER_LORA_RANK="${ENCODER_LORA_RANK:-8}"
export ENCODER_LORA_ALPHA="${ENCODER_LORA_ALPHA:-16.0}"
export ENCODER_LORA_DROPOUT="${ENCODER_LORA_DROPOUT:-0.05}"
export ENCODER_LORA_LAST_N_BLOCKS="${ENCODER_LORA_LAST_N_BLOCKS:-0}"
export ENCODER_LORA_LR_MULT="${ENCODER_LORA_LR_MULT:-0.5}"
export ENCODER_LORA_WEIGHT_DECAY="${ENCODER_LORA_WEIGHT_DECAY:-0.0001}"
export ENCODER_LORA_ACTIVATION_CHECKPOINTING="${ENCODER_LORA_ACTIVATION_CHECKPOINTING:-1}"
export ENCODER_LORA_TARGET_SUFFIXES="${ENCODER_LORA_TARGET_SUFFIXES:-attn.qkv,attn.proj}"

export TRI_MODAL_USE_GAZE_BRANCH="${TRI_MODAL_USE_GAZE_BRANCH:-1}"
export TRI_MODAL_USE_IMU_BRANCH="${TRI_MODAL_USE_IMU_BRANCH:-1}"
export TRI_MODAL_GAZE_TOKEN_RATIO="${TRI_MODAL_GAZE_TOKEN_RATIO:-0.5}"
export TRI_MODAL_IMU_TOKEN_RATIO="${TRI_MODAL_IMU_TOKEN_RATIO:-0.1}"
export TRI_MODAL_GAZE_GRID_SIZE="${TRI_MODAL_GAZE_GRID_SIZE:-10}"
export TRI_MODAL_IMU_ENCODER_TYPE="${TRI_MODAL_IMU_ENCODER_TYPE:-gru}"
export TRI_MODAL_FUSION_NUM_HEADS="${TRI_MODAL_FUSION_NUM_HEADS:-4}"
export TRI_MODAL_FUSION_NUM_LAYERS="${TRI_MODAL_FUSION_NUM_LAYERS:-1}"
export TRI_MODAL_USE_GATED_RESIDUAL="${TRI_MODAL_USE_GATED_RESIDUAL:-1}"
export TRI_MODAL_FUSION_LR_MULT="${TRI_MODAL_FUSION_LR_MULT:-0.05}"
export TRI_MODAL_FUSION_WEIGHT_DECAY="${TRI_MODAL_FUSION_WEIGHT_DECAY:-0.0001}"
export TRI_MODAL_IMU_HIDDEN_DIM="${TRI_MODAL_IMU_HIDDEN_DIM:-128}"

export POSE_SLAM_ROOT="${POSE_SLAM_ROOT:-${GAZE_ROOT}/P01/SLAM/multi}"
export POSE_MAPPING_JSON="${POSE_MAPPING_JSON:-${POSE_SLAM_ROOT}/vrs_to_multi_slam.json}"
export POSE_FEATURE_SET="${POSE_FEATURE_SET:-pose_6d}"
export POSE_QUALITY_MIN="${POSE_QUALITY_MIN:-0.0}"
export POSE_HISTORY_SEC="${POSE_HISTORY_SEC:-0}"
export POSE_INTERFRAME_K_MAX="${POSE_INTERFRAME_K_MAX:-128}"

export BACKBONE="${BACKBONE:-vitl}"
export EVAL_RESOLUTION="${EVAL_RESOLUTION:-256}"
export EVAL_USE_BFLOAT16="${EVAL_USE_BFLOAT16:-0}"
export EVAL_NUM_WORKERS="${EVAL_NUM_WORKERS:-2}"
export EVAL_VAL_NUM_WORKERS="${EVAL_VAL_NUM_WORKERS:-2}"
export EVAL_MAX_TRAIN_ITERS="${EVAL_MAX_TRAIN_ITERS:-0}"
export GAZE_DECODER_NUM_THREADS="${GAZE_DECODER_NUM_THREADS:-2}"

export DEBUG_SUBSET_PATH="${DEBUG_SUBSET_PATH:-}"
export LORA_TAG="${LORA_TAG:-hdepic-tri-modal-fusion-vitl-1s-enclora}"
export CONFIG_PATH="${CONFIG_PATH:-${PROJECT_ROOT}/configs/generated/hdepic_tri_modal_fusion_1s_fulltrain.yaml}"
export RESUME_CHECKPOINT="${RESUME_CHECKPOINT:-0}"

echo "[tri-modal] mode=${GAZE_MODE} gaze=${TRI_MODAL_USE_GAZE_BRANCH} imu=${TRI_MODAL_USE_IMU_BRANCH}"
echo "[tri-modal] fusion heads=${TRI_MODAL_FUSION_NUM_HEADS} layers=${TRI_MODAL_FUSION_NUM_LAYERS} gated=${TRI_MODAL_USE_GATED_RESIDUAL}"
echo "[tri-modal] encoder_lora=${ENCODER_LORA_ENABLED} batch=${EVAL_BATCH_SIZE} epochs=${EVAL_NUM_EPOCHS}"

bash "${PROJECT_ROOT}/scripts/run_hdepic_lora_probe.slurm"
